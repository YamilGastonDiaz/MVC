@model Obra

@{
    ViewData["Title"] = "Detalle";
}

<div class="container mb-4">
    <section class="row justify-content-center">
        <div class="text-center">
            <h1>Detalle Obra</h1>
        </div>

        <hr />

        <div class="card mb-3" style="max-width: 840px;">
            <div class="row g-0">
                <div class="col-md-6">
                    <img src="@Model.UrlImagen" class="img-fluid rounded-start" style="height:350px; object-fit:cover;" alt="...">
                </div>
                <div class="col-md-6">
                    <div class="card-body">
                        <span class="m-0 p-0 fw-bold" style="font-size:12px;">TITULO:</span>
                        <h5 class="card-title">@Model.Titulo</h5>
                        <span class="m-0 p-0 fw-bold" style="font-size:12px;">ESTILO:</span>
                        <p class="card-text">@Model.Estilo</p>
                        <span class="m-0 p-0 fw-bold" style="font-size:12px;">ARTISTA:</span>
                        <p class="card-text">@Model.Artista.Nombre</p>
                        <p class="card-text"><small class="text-body-secondary">PAIS: @Model.Artista.Pais</small></p>
                    </div>
                </div>
            </div>
        </div>

        <div class="form-group mb-3 text-center">
            @*<a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Id">Editar</a>*@
            <a class="btn btn-secondary" asp-controller="Exposicion" asp-action="Details" asp-route-id="@ViewBag.idExpo">Volver</a>
        </div>
    </section>
</div>